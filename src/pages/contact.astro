---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact — Collectif Cobalt"
  description="Contactez le Collectif Cobalt pour un projet d'architecture, de design d'espace, de fabrication ou de média en Nouvelle-Aquitaine."
  current="contact"
>
  <!-- HERO CONTACT -->
  <div class="contact-hero">
    <div class="ch-left sr">
      <div class="s-label">Contact</div>
      <h1 class="ch-title">TRAVAILLONS<br />ENSEMBLE.</h1>
      <div class="ch-info">
        <div class="ch-block">
          <p class="ch-block-lbl">Studio</p>
          <p class="ch-block-val">Cobalt+ — Architecture & Design d'espace<br />Nouvelle-Aquitaine, France</p>
        </div>
        <div class="ch-block">
          <p class="ch-block-lbl">Email général</p>
          <p class="ch-block-val"><a href="mailto:studio@collectifcobalt.eu">studio@collectifcobalt.eu</a></p>
        </div>
        <div class="ch-block">
          <p class="ch-block-lbl">Association étudiante</p>
          <p class="ch-block-val">Bleu de Cobalt<br /><a href="mailto:bleu@collectifcobalt.eu">bleu@collectifcobalt.eu</a></p>
        </div>
        <div class="ch-block">
          <p class="ch-block-lbl">Réseaux</p>
          <p class="ch-block-val">
            <a href="https://www.instagram.com/collectifcobalt" target="_blank" rel="noopener">Instagram</a> · <a href="https://www.linkedin.com/company/collectif-cobalt" target="_blank" rel="noopener">LinkedIn</a> · <a href="https://www.behance.net/collectifcobalt" target="_blank" rel="noopener">Behance</a>
          </p>
        </div>
      </div>
    </div>
    <div class="ch-right sr sr-d2">
      <h2 class="ch-form-title">Un projet en tête ?</h2>
      <form class="ch-form" id="contact-form" action="https://formspree.io/f/{FORM_ID}" method="POST">
        <input type="hidden" name="_subject" id="form-subject-hidden" value="Nouveau message — Studio" />
        <input type="hidden" name="_replyto" id="form-replyto-hidden" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="ch-row">
          <div class="ch-field"><label class="ch-lbl" for="f-prenom">Prénom</label><input class="ch-input" id="f-prenom" name="prenom" type="text" placeholder="Camille" required /></div>
          <div class="ch-field"><label class="ch-lbl" for="f-nom">Nom</label><input class="ch-input" id="f-nom" name="nom" type="text" placeholder="Dupont" /></div>
        </div>
        <div class="ch-field"><label class="ch-lbl" for="f-email">Email</label><input class="ch-input" id="f-email" name="email" type="email" placeholder="camille@mail.fr" required /></div>
        <div class="ch-subject">
          <label class="ch-lbl">Sujet</label>
          <div class="ch-subject-opts">
            <button type="button" class="ch-subject-btn sel" data-subject="Studio">Studio</button>
            <button type="button" class="ch-subject-btn" data-subject="Atelier">Atelier</button>
            <button type="button" class="ch-subject-btn" data-subject="Bleu de Cobalt">Bleu de Cobalt</button>
            <button type="button" class="ch-subject-btn" data-subject="Le Média">Le Média</button>
            <button type="button" class="ch-subject-btn" data-subject="Autre">Autre</button>
          </div>
        </div>
        <div class="ch-field"><label class="ch-lbl" for="f-message">Message</label><textarea class="ch-ta" id="f-message" name="message" placeholder="Décrivez votre projet, vos contraintes, votre ambition…" required></textarea></div>
        <button type="submit" class="ch-submit" id="form-submit"><span>Envoyer ma demande →</span></button>
        <div class="ch-feedback success" id="form-success" role="status">✓ Message envoyé — nous vous répondrons sous 48 h.</div>
        <div class="ch-feedback error" id="form-error" role="alert">Une erreur est survenue. Réessayez ou écrivez-nous directement à <a href="mailto:team@collectifcobalt.eu" style="color:inherit;text-decoration:underline">team@collectifcobalt.eu</a>.</div>
      </form>
    </div>
  </div>

  <!-- TEAM -->
  <section id="team">
    <div class="s-label sr">L'équipe</div>
    <div class="team-grid">
      <div class="team-card sr">
        <div class="team-photo"><img src="/assets/TEAM/gambi.jpg" alt="Gambi" loading="lazy" /></div>
        <div class="team-body">
          <div class="team-card-hd"><h3 class="team-name">Gambi</h3><div class="team-pip"></div></div>
          <p class="team-role">Architecte · Le Studio</p>
          <p class="team-bio">Architecte d'intérieur diplômé, Gambi coordonne la vision créative du collectif. Rigoureux, il porte l'exigence formelle et spatiale de chaque projet.</p>
          <div class="team-tags"><span class="team-tag">Architecture</span><span class="team-tag">Direction créative</span><span class="team-tag">Espace</span></div>
          <a href="mailto:gambi@collectifcobalt.eu" class="team-contact"><span class="email">gambi@collectifcobalt.eu</span><span class="arrow">→</span></a>
        </div>
      </div>
      <div class="team-card sr sr-d1">
        <div class="team-photo"><img src="/assets/TEAM/lola.jpg" alt="Lola" loading="lazy" /></div>
        <div class="team-body">
          <div class="team-card-hd"><h3 class="team-name">Lola</h3><div class="team-pip"></div></div>
          <p class="team-role">Designer · L'Atelier</p>
          <p class="team-bio">Spécialiste des matières locales et des finitions, Lola apporte une sensibilité unique à chaque projet. Elle coordonne les relations avec les artisans.</p>
          <div class="team-tags"><span class="team-tag">Design d'espace</span><span class="team-tag">Matériaux</span><span class="team-tag">Artisanat</span></div>
          <a href="mailto:lola@collectifcobalt.eu" class="team-contact"><span class="email">lola@collectifcobalt.eu</span><span class="arrow">→</span></a>
        </div>
      </div>
      <div class="team-card sr sr-d2">
        <div class="team-photo"><img src="/assets/TEAM/lou-ann.jpg" alt="Lou-Ann" loading="lazy" /></div>
        <div class="team-body">
          <div class="team-card-hd"><h3 class="team-name">Lou-Ann</h3><div class="team-pip"></div></div>
          <p class="team-role">Fabrication · Bleu de Cobalt</p>
          <p class="team-bio">À la tête de l'Atelier et de Bleu de Cobalt, Lou-Ann incarne le lien entre pensée et fabrication. Elle coordonne les missions étudiantes et la production.</p>
          <div class="team-tags"><span class="team-tag">Fabrication</span><span class="team-tag">Pédagogie</span><span class="team-tag">Transmission</span></div>
          <a href="mailto:louann@collectifcobalt.eu" class="team-contact"><span class="email">louann@collectifcobalt.eu</span><span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- TÉMOIGNAGES -->
  <section id="temoignages">
    <div class="s-label on-color sr">Ce qu'on dit de nous</div>
    <h2 class="testi-title sr">ILS NOUS<br />FONT CONFIANCE.</h2>
    <div class="testi-grid">
      <div class="testi-item sr">
        <div class="testi-mark">"</div>
        <p class="testi-txt">Une approche rare : ils pensent le projet dans sa globalité, de l'intention à la matière. Le résultat dépasse ce qu'on espérait.</p>
        <p class="testi-src">Client résidentiel — Bordeaux, 2025</p>
      </div>
      <div class="testi-item sr sr-d1">
        <div class="testi-mark">"</div>
        <p class="testi-txt">Le Collectif Cobalt a transformé notre local en espace de vie réel. Écoute, proposition, exécution — avec une rigueur exceptionnelle.</p>
        <p class="testi-src">Artisan ébéniste — Périgueux, 2026</p>
      </div>
      <div class="testi-item sr sr-d2">
        <div class="testi-mark">"</div>
        <p class="testi-txt">Jeunes mais matures. Leur maîtrise des matériaux locaux et leur exigence formelle apportent une vraie identité à chaque espace.</p>
        <p class="testi-src">Architecte partenaire — Bayonne, 2026</p>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  const subjectHidden = document.getElementById('form-subject-hidden');
  document.querySelectorAll('.ch-subject-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.ch-subject-btn').forEach((b) => b.classList.remove('sel'));
      btn.classList.add('sel');
      if (subjectHidden) subjectHidden.value = `Nouveau message — ${btn.dataset.subject}`;
    });
  });

  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('form-submit');
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const emailInput = document.getElementById('f-email');

  if (emailInput) {
    emailInput.addEventListener('input', (e) => {
      const replyto = document.getElementById('form-replyto-hidden');
      if (replyto) replyto.value = e.target.value;
    });
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }
      submitBtn.disabled = true;
      submitBtn.querySelector('span').textContent = 'Envoi en cours…';
      successEl.classList.remove('visible');
      errorEl.classList.remove('visible');
      try {
        const data = new FormData(form);
        const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
        if (res.ok) {
          form.reset();
          document.querySelectorAll('.ch-subject-btn').forEach((b) => b.classList.remove('sel'));
          document.querySelector('.ch-subject-btn[data-subject="Studio"]').classList.add('sel');
          if (subjectHidden) subjectHidden.value = 'Nouveau message — Studio';
          successEl.classList.add('visible');
          submitBtn.querySelector('span').textContent = 'Message envoyé ✓';
        } else {
          throw new Error(res.status);
        }
      } catch {
        errorEl.classList.add('visible');
        submitBtn.disabled = false;
        submitBtn.querySelector('span').textContent = 'Envoyer ma demande →';
      }
    });
  }
</script>

<style is:global>
  /* HERO CONTACT */
  .contact-hero {
    padding: 140px 44px 0; background: var(--cream);
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: end;
    border-bottom: 2px solid var(--noir);
  }
  .ch-left { padding-bottom: 80px; }
  .ch-title { font-family: var(--f-display); font-size: clamp(64px,10vw,120px); line-height: .86; margin-bottom: 40px; }
  .ch-info { display: flex; flex-direction: column; gap: 32px; }
  .ch-block-lbl { font-size: .6rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: rgba(26,26,26,.35); margin-bottom: 8px; }
  .ch-block-val { font-size: .95rem; font-weight: 400; line-height: 1.6; }
  .ch-block-val a { transition: color .15s; }
  .ch-block-val a:hover { color: var(--bleu); }

  .ch-right {
    background: rgba(26,26,26,0.92); padding: 80px 60px;
    border-radius: var(--r-lg);
    backdrop-filter: var(--blur); -webkit-backdrop-filter: var(--blur);
    border: 1px solid rgba(255,255,255,.08);
    box-shadow: var(--shadow-lg);
  }
  .ch-form-title { font-family: var(--f-serif); font-style: italic; font-size: clamp(2rem,3.5vw,3rem); color: var(--cream); margin-bottom: 40px; line-height: 1; letter-spacing: -.02em; }
  .ch-form { display: flex; flex-direction: column; gap: 24px; }
  .ch-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .ch-field { display: flex; flex-direction: column; gap: 8px; }
  .ch-lbl { font-size: .6rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; color: rgba(240,235,216,.3); }
  .ch-input, .ch-ta {
    background: transparent; border: none; border-bottom: 1.5px solid rgba(240,235,216,.18);
    padding: 12px 0; font-family: var(--f-body); font-size: .88rem; font-weight: 300;
    color: var(--cream); outline: none; transition: border-color .2s;
  }
  .ch-ta { resize: none; min-height: 90px; }
  .ch-input:focus, .ch-ta:focus { border-color: var(--bleu); }
  .ch-input::placeholder, .ch-ta::placeholder { color: rgba(240,235,216,.15); }
  .ch-subject { display: flex; flex-direction: column; gap: 8px; }
  .ch-subject-opts { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 4px; }
  .ch-subject-btn {
    padding: 7px 16px; border-radius: var(--r-pill);
    border: 1px solid rgba(240,235,216,.18); background: transparent;
    font-family: var(--f-body); font-size: .68rem; font-weight: 600;
    letter-spacing: .08em; text-transform: uppercase; color: rgba(240,235,216,.4);
    transition: all .2s;
  }
  .ch-subject-btn.sel { background: var(--bleu); color: var(--cream); border-color: var(--bleu); }
  .ch-subject-btn:hover:not(.sel) { border-color: rgba(240,235,216,.4); color: rgba(240,235,216,.7); }
  .ch-submit {
    position: relative; overflow: hidden; padding: 16px 40px; border-radius: var(--r-pill);
    border: none; font-family: var(--f-body); font-size: .75rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase; background: var(--cream); color: var(--noir);
    transition: color .35s; align-self: flex-start;
  }
  .ch-submit::before {
    content: ''; position: absolute; inset: 0; border-radius: var(--r-pill);
    background: var(--bleu); transform: translateX(-101%);
    transition: transform .35s cubic-bezier(.76,0,.24,1);
  }
  .ch-submit:hover { color: var(--cream); }
  .ch-submit:hover::before { transform: translateX(0); }
  .ch-submit span { position: relative; z-index: 1; }
  .ch-submit:disabled { opacity: .6; pointer-events: none; }

  .ch-feedback {
    display: none; padding: 18px 24px; border-radius: var(--r-md);
    font-size: .82rem; font-weight: 400; line-height: 1.6;
    margin-top: 8px;
  }
  .ch-feedback.success { background: rgba(93,161,107,.18); border: 1px solid rgba(93,161,107,.4); color: #8dd69d; }
  .ch-feedback.error { background: rgba(187,59,52,.18); border: 1px solid rgba(187,59,52,.4); color: #f08880; }
  .ch-feedback.visible { display: block; }

  /* TEAM */
  #team { padding: 100px 44px; background: var(--cream); border-top: 2px solid var(--noir); }
  .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 52px; }
  .team-card {
    background: #fff; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 4px rgba(0,0,0,.04), 0 8px 28px rgba(0,0,0,.09);
    transition: transform .32s cubic-bezier(.25,.46,.45,.94), box-shadow .32s;
  }
  .team-card:hover { transform: translateY(-7px); box-shadow: 0 4px 8px rgba(0,0,0,.06), 0 20px 52px rgba(0,0,0,.15); }
  .team-photo { width: 100%; aspect-ratio: 3/4; overflow: hidden; background: #1a1a1a; }
  .team-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease, filter .4s ease; filter: grayscale(15%); }
  .team-card:hover .team-photo img { transform: scale(1.04); filter: grayscale(0%); }
  .team-body { padding: 26px 26px 30px; }
  .team-card-hd { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 5px; }
  .team-name { font-family: var(--f-display); font-size: clamp(20px, 2.2vw, 26px); letter-spacing: -.02em; line-height: 1; color: var(--noir); }
  .team-pip { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
  .team-card:nth-child(1) .team-pip { background: var(--bleu);  box-shadow: 0 0 8px rgba(74,130,220,.6); }
  .team-card:nth-child(2) .team-pip { background: var(--jaune); box-shadow: 0 0 8px rgba(241,203,79,.6); }
  .team-card:nth-child(3) .team-pip { background: var(--vert);  box-shadow: 0 0 8px rgba(93,161,107,.6); }
  .team-role { font-size: .6rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 18px; }
  .team-card:nth-child(1) .team-role { color: var(--bleu); }
  .team-card:nth-child(2) .team-role { color: #B8940A; }
  .team-card:nth-child(3) .team-role { color: var(--vert); }
  .team-bio { font-size: .81rem; line-height: 1.74; font-weight: 300; color: rgba(26,26,26,.58); margin-bottom: 20px; }
  .team-tags { display: flex; gap: 7px; flex-wrap: wrap; margin-bottom: 22px; }
  .team-tag { padding: 5px 13px; border-radius: var(--r-pill); font-size: .58rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; border: 1.5px solid; }
  .team-card:nth-child(1) .team-tag { border-color: rgba(74,130,220,.3);  color: rgba(74,130,220,.85); }
  .team-card:nth-child(2) .team-tag { border-color: rgba(241,203,79,.5);  color: rgba(184,148,10,.85); }
  .team-card:nth-child(3) .team-tag { border-color: rgba(93,161,107,.35); color: rgba(60,135,78,.85); }
  .team-contact {
    display: flex; align-items: center; gap: 8px;
    padding-top: 18px; border-top: 1px solid rgba(26,26,26,.07);
    font-size: .72rem; font-weight: 500;
    color: rgba(26,26,26,.35); transition: color .18s;
  }
  .team-contact:hover { color: var(--noir); }
  .team-contact .email { flex: 1; }
  .team-contact .arrow { transition: transform .2s; font-size: .82rem; }
  .team-contact:hover .arrow { transform: translateX(3px); }

  /* TÉMOIGNAGES */
  #temoignages { background: var(--jaune); padding: 100px 44px; border-top: 2px solid var(--noir); }
  #temoignages .s-label { color: rgba(26,26,26,.5); }
  #temoignages .s-label::before { background: rgba(26,26,26,.4); }
  .testi-title { font-family: var(--f-display); font-size: clamp(48px,6vw,80px); line-height: .9; margin-bottom: 56px; }
  .testi-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0; border-top: 2px solid var(--noir); }
  .testi-item {
    padding: 44px 36px; border-right: 2px solid var(--noir); position: relative;
    background: rgba(255,255,255,.25);
    backdrop-filter: var(--blur); -webkit-backdrop-filter: var(--blur);
    border-radius: var(--r-md); margin: 25px;
    transition: transform .25s;
  }
  .testi-item:hover { transform: translateY(-3px); }
  .testi-item:last-child { border-right: none; }
  .testi-mark { font-family: var(--f-serif); font-style: italic; font-size: 5rem; line-height: .6; color: rgba(26,26,26,.08); position: absolute; top: 20px; left: 24px; }
  .testi-txt { font-family: var(--f-serif); font-style: italic; font-size: 1rem; line-height: 1.7; color: rgba(26,26,26,.78); margin-bottom: 20px; padding-top: 16px; }
  .testi-src { font-size: .6rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: rgba(26,26,26,.4); }

  @media (max-width: 960px) {
    .contact-hero { grid-template-columns: 1fr; padding: 110px 20px 0; gap: 0; }
    .ch-left { padding-bottom: 48px; }
    .ch-title { font-size: clamp(48px, 11vw, 88px); margin-bottom: 32px; }
    .ch-right { padding: 48px 24px; border-radius: var(--r-md); margin-bottom: 32px; }
    .ch-form-title { font-size: clamp(1.8rem, 6vw, 2.4rem); margin-bottom: 28px; }
    .ch-row { grid-template-columns: 1fr; }
    #team { padding: 64px 20px; }
    .team-grid { grid-template-columns: 1fr; gap: 16px; }
    #temoignages { padding: 64px 20px; }
    .testi-title { font-size: clamp(36px, 9vw, 56px); margin-bottom: 36px; }
    .testi-grid { grid-template-columns: 1fr; }
    .testi-item { border-right: none; border-bottom: 2px solid var(--noir); margin: 8px; padding: 32px 24px; }
    .testi-item:last-child { border-bottom: none; }
  }
  @media (max-width: 560px) {
    .contact-hero { padding: 96px 18px 0; }
    .ch-title { font-size: clamp(40px, 13vw, 64px); }
    .ch-info { gap: 24px; }
    .ch-block-val { font-size: .9rem; }
    .ch-right { padding: 36px 20px; }
    .ch-subject-opts { gap: 6px; }
    .ch-subject-btn { padding: 6px 12px; font-size: .62rem; }
    .ch-submit { padding: 14px 28px; font-size: .68rem; }
    #team { padding: 52px 16px; }
    .team-photo { aspect-ratio: 4/3; }
    .team-body { padding: 20px 20px 24px; }
    .team-name { font-size: 19px; }
    .team-bio { font-size: .79rem; }
    #temoignages { padding: 52px 16px; }
    .testi-item { margin: 4px; padding: 28px 20px; }
    .testi-mark { font-size: 4rem; top: 16px; left: 18px; }
    .testi-txt { font-size: .92rem; padding-top: 12px; }
  }
</style>
