---
import Base from '../layouts/Base.astro';
---

<Base
  title="Services — Collectif Cobalt"
  description="Les services du Collectif Cobalt : architecture d'intérieur, design d'espace, maîtrise d'œuvre en Nouvelle-Aquitaine."
  current="services"
>
  <section id="config">
    <div class="cfg-wrap">
      <div class="cfg-head sr">
        <div class="s-label on-dark">Démarrer un projet</div>
        <h2 class="cfg-title">Parlons de votre projet.</h2>
        <p class="cfg-sub">6 étapes pour mieux comprendre votre besoin.</p>
      </div>
      <div class="cfg-steps" id="cfg-steps">
        <div class="step-dash cur"></div>
        <div class="step-dash"></div>
        <div class="step-dash"></div>
        <div class="step-dash"></div>
        <div class="step-dash"></div>
        <div class="step-dash"></div>
      </div>

      <!-- Étape 1 -->
      <div class="cfg-panel active" data-p="0">
        <p class="cfg-step-lbl">Étape 01 — Type de projet</p>
        <h3 class="cfg-q">Quel type d'espace souhaitez-vous concevoir ?</h3>
        <div class="cfg-opts">
          <button class="cfg-opt">
            <div class="cfg-opt-n">01</div>
            <svg width="40" height="26" viewBox="0 0 750 450" fill="currentColor" style="opacity:.3"><path d="M0 160L750 160L750 450L0 450Z"/><path d="M375 0L750 160L0 160Z"/></svg>
            <div class="cfg-opt-lbl">Résidentiel</div>
            <div class="cfg-opt-sub">Maison, appartement, villa</div>
          </button>
          <button class="cfg-opt">
            <div class="cfg-opt-n">02</div>
            <svg width="40" height="26" viewBox="0 0 750 450" fill="currentColor" style="opacity:.3"><rect x="0" y="220" width="750" height="230"/><rect x="60" y="0" width="130" height="220"/><rect x="280" y="60" width="130" height="160"/><rect x="500" y="30" width="130" height="190"/></svg>
            <div class="cfg-opt-lbl">Commerce / Hospitality</div>
            <div class="cfg-opt-sub">Restaurant, boutique, hôtel</div>
          </button>
          <button class="cfg-opt">
            <div class="cfg-opt-n">03</div>
            <svg width="40" height="26" viewBox="0 0 750 450" fill="currentColor" style="opacity:.3"><rect x="0" y="200" width="750" height="250"/><rect x="80" y="0" width="560" height="200"/></svg>
            <div class="cfg-opt-lbl">Bureaux / Coworking</div>
            <div class="cfg-opt-sub">Espace de travail, studio</div>
          </button>
          <button class="cfg-opt">
            <div class="cfg-opt-n">04</div>
            <svg width="40" height="26" viewBox="0 0 750 450" fill="currentColor" style="opacity:.3"><rect x="0" y="300" width="750" height="150"/><rect x="0" y="0" width="180" height="300"/><rect x="570" y="0" width="180" height="300"/><path d="M180 0 A195 300 0 0 1 570 0Z"/></svg>
            <div class="cfg-opt-lbl">Lieu culturel</div>
            <div class="cfg-opt-sub">Galerie, tiers-lieu, école</div>
          </button>
        </div>
        <div class="cfg-nav"><span></span><button class="cfg-next" data-action="next"><span>Étape suivante →</span></button></div>
      </div>

      <!-- Étape 2 -->
      <div class="cfg-panel" data-p="1">
        <p class="cfg-step-lbl">Étape 02 — Surface</p>
        <h3 class="cfg-q">Quelle est la surface approximative ?</h3>
        <div class="cfg-opts">
          <button class="cfg-opt"><div class="cfg-opt-n">01</div><div class="cfg-opt-lbl">Moins de 50 m²</div><div class="cfg-opt-sub">Studio, boutique</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">02</div><div class="cfg-opt-lbl">50 à 150 m²</div><div class="cfg-opt-sub">Appartement, commerce</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">03</div><div class="cfg-opt-lbl">150 à 400 m²</div><div class="cfg-opt-sub">Maison, grand commerce</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">04</div><div class="cfg-opt-lbl">Plus de 400 m²</div><div class="cfg-opt-sub">Grand projet, lieu culturel</div></button>
        </div>
        <div class="cfg-nav"><button class="cfg-back" data-action="prev">Retour</button><button class="cfg-next" data-action="next"><span>Étape suivante →</span></button></div>
      </div>

      <!-- Étape 3 -->
      <div class="cfg-panel" data-p="2">
        <p class="cfg-step-lbl">Étape 03 — Phase</p>
        <h3 class="cfg-q">Où en êtes-vous dans votre projet ?</h3>
        <div class="cfg-opts">
          <button class="cfg-opt"><div class="cfg-opt-n">01</div><div class="cfg-opt-lbl">Au stade de l'idée</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">02</div><div class="cfg-opt-lbl">Esquisse / programme</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">03</div><div class="cfg-opt-lbl">Permis / autorisations</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">04</div><div class="cfg-opt-lbl">Prêt au chantier</div></button>
        </div>
        <div class="cfg-nav"><button class="cfg-back" data-action="prev">Retour</button><button class="cfg-next" data-action="next"><span>Étape suivante →</span></button></div>
      </div>

      <!-- Étape 4 -->
      <div class="cfg-panel" data-p="3">
        <p class="cfg-step-lbl">Étape 04 — Budget</p>
        <h3 class="cfg-q">Quel est l'ordre de grandeur de votre budget ?</h3>
        <div class="cfg-opts">
          <button class="cfg-opt"><div class="cfg-opt-n">01</div><div class="cfg-opt-lbl">Moins de 20 000 €</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">02</div><div class="cfg-opt-lbl">20 000 — 60 000 €</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">03</div><div class="cfg-opt-lbl">60 000 — 200 000 €</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">04</div><div class="cfg-opt-lbl">Plus de 200 000 €</div></button>
        </div>
        <div class="cfg-nav"><button class="cfg-back" data-action="prev">Retour</button><button class="cfg-next" data-action="next"><span>Étape suivante →</span></button></div>
      </div>

      <!-- Étape 5 -->
      <div class="cfg-panel" data-p="4">
        <p class="cfg-step-lbl">Étape 05 — Localisation</p>
        <h3 class="cfg-q">Où se situe le projet ?</h3>
        <div class="cfg-opts" style="grid-template-columns:repeat(auto-fill,minmax(160px,1fr))">
          <button class="cfg-opt"><div class="cfg-opt-n">01</div><div class="cfg-opt-lbl">Bordeaux</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">02</div><div class="cfg-opt-lbl">Pays Basque</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">03</div><div class="cfg-opt-lbl">Dordogne</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">04</div><div class="cfg-opt-lbl">Autre Nouvelle-Aquitaine</div></button>
          <button class="cfg-opt"><div class="cfg-opt-n">05</div><div class="cfg-opt-lbl">Hors région</div></button>
        </div>
        <div class="cfg-nav"><button class="cfg-back" data-action="prev">Retour</button><button class="cfg-next" data-action="next"><span>Étape suivante →</span></button></div>
      </div>

      <!-- Étape 6 -->
      <div class="cfg-panel" data-p="5">
        <p class="cfg-step-lbl">Étape 06 — Coordonnées</p>
        <h3 class="cfg-q">Comment vous contacter ?</h3>
        <form class="cfg-form" id="cfg-form-svc">
          <div class="cfg-row">
            <div class="cfg-field"><label class="cfg-lbl">Prénom</label><input class="cfg-input" type="text" placeholder="Camille" /></div>
            <div class="cfg-field"><label class="cfg-lbl">Nom</label><input class="cfg-input" type="text" placeholder="Dupont" /></div>
          </div>
          <div class="cfg-row">
            <div class="cfg-field"><label class="cfg-lbl">Email</label><input class="cfg-input" type="email" placeholder="camille@mail.fr" /></div>
            <div class="cfg-field"><label class="cfg-lbl">Téléphone</label><input class="cfg-input" type="tel" placeholder="+33 6 …" /></div>
          </div>
          <div class="cfg-field"><label class="cfg-lbl">Message libre</label><textarea class="cfg-ta" placeholder="Décrivez votre projet, vos contraintes, votre ambition…"></textarea></div>
          <div class="cfg-nav"><button type="button" class="cfg-back" data-action="prev">Retour</button><button type="submit" class="cfg-next"><span>Envoyer ma demande →</span></button></div>
        </form>
      </div>
    </div>
  </section>
</Base>

<script is:inline>
  let cfgStep = 0;
  function cfgUpdateDashes() {
    document.querySelectorAll('.step-dash').forEach((d, i) => {
      d.classList.toggle('done', i < cfgStep);
      d.classList.toggle('cur', i === cfgStep);
    });
  }
  function cfgNext() {
    if (cfgStep < 5) {
      document.querySelector(`[data-p="${cfgStep}"]`).classList.remove('active');
      cfgStep++;
      document.querySelector(`[data-p="${cfgStep}"]`).classList.add('active');
      cfgUpdateDashes();
    }
  }
  function cfgPrev() {
    if (cfgStep > 0) {
      document.querySelector(`[data-p="${cfgStep}"]`).classList.remove('active');
      cfgStep--;
      document.querySelector(`[data-p="${cfgStep}"]`).classList.add('active');
      cfgUpdateDashes();
    }
  }
  document.querySelectorAll('[data-action="next"]').forEach((b) => b.addEventListener('click', cfgNext));
  document.querySelectorAll('[data-action="prev"]').forEach((b) => b.addEventListener('click', cfgPrev));
  document.querySelectorAll('.cfg-opt').forEach((o) => {
    o.addEventListener('click', () => {
      o.closest('.cfg-opts').querySelectorAll('.cfg-opt').forEach((x) => x.classList.remove('sel'));
      o.classList.add('sel');
    });
  });
  const sf = document.getElementById('cfg-form-svc');
  if (sf) sf.addEventListener('submit', (e) => { e.preventDefault(); alert('Merci ! On revient vers toi rapidement.'); });
</script>

<style is:global>
  /* CONFIGURATEUR */
  #config { background: var(--noir); padding: 100px 0 0; }
  .cfg-wrap { max-width: 820px; margin: 0 auto; padding: 0 44px 100px; }
  .cfg-head { margin-bottom: 56px; }
  .cfg-title { font-family: var(--f-serif); font-style: italic; font-size: clamp(3rem,5vw,5rem); line-height: .92; color: var(--cream); margin-bottom: 14px; letter-spacing: -.02em; }
  .cfg-sub { font-size: .9rem; font-weight: 300; color: rgba(240,235,216,.45); }
  .cfg-steps { display: flex; gap: 8px; margin-bottom: 52px; }
  .step-dash { height: 2px; flex: 1; background: rgba(240,235,216,.12); transition: background .3s; }
  .step-dash.done { background: var(--bleu); }
  .step-dash.cur  { background: rgba(74,130,220,.45); }
  .cfg-panel { display: none; }
  .cfg-panel.active { display: block; }
  .cfg-step-lbl { font-size: .6rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: rgba(240,235,216,.3); margin-bottom: 20px; }
  .cfg-q { font-family: var(--f-body); font-weight: 600; font-size: 1.25rem; color: var(--cream); margin-bottom: 28px; line-height: 1.3; }
  .cfg-opts { display: grid; gap: 10px; grid-template-columns: repeat(auto-fill,minmax(190px,1fr)); }
  .cfg-opt {
    padding: 26px 22px; border: 1px solid rgba(240,235,216,.13);
    background: transparent; text-align: left; border-radius: var(--r-sm);
    display: flex; flex-direction: column; gap: 10px;
    transition: border-color .2s, background .2s;
    color: rgba(240,235,216,.65);
  }
  .cfg-opt:hover { border-color: rgba(240,235,216,.3); }
  .cfg-opt.sel { background: var(--cream); color: var(--noir); border-color: var(--cream); }
  .cfg-opt-n { font-family: var(--f-serif); font-style: italic; font-size: 2rem; color: rgba(240,235,216,.1); line-height: 1; transition: color .2s; }
  .cfg-opt.sel .cfg-opt-n { color: rgba(26,26,26,.1); }
  .cfg-opt-lbl { font-size: .8rem; font-weight: 600; color: rgba(240,235,216,.65); transition: color .2s; }
  .cfg-opt.sel .cfg-opt-lbl { color: var(--noir); }
  .cfg-opt-sub { font-size: .7rem; font-weight: 300; color: rgba(240,235,216,.3); line-height: 1.5; transition: color .2s; }
  .cfg-opt.sel .cfg-opt-sub { color: rgba(26,26,26,.5); }
  .cfg-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 44px; padding-top: 28px; border-top: 1px solid rgba(240,235,216,.08); }
  .cfg-back { font-size: .7rem; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; color: rgba(240,235,216,.28); background: none; border: none; font-family: var(--f-body); transition: color .15s; display: flex; align-items: center; gap: 8px; }
  .cfg-back:hover { color: rgba(240,235,216,.6); }
  .cfg-back::before { content: '←'; }
  .cfg-next {
    position: relative; overflow: hidden; padding: 14px 36px; border-radius: var(--r-pill); border: none;
    font-family: var(--f-body); font-size: .75rem; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; background: var(--cream); color: var(--noir); transition: color .35s;
  }
  .cfg-next::before {
    content: ''; position: absolute; inset: 0; border-radius: var(--r-pill);
    background: var(--bleu); transform: translateX(-101%);
    transition: transform .35s cubic-bezier(.76,0,.24,1);
  }
  .cfg-next:hover { color: var(--cream); }
  .cfg-next:hover::before { transform: translateX(0); }
  .cfg-next span { position: relative; z-index: 1; }

  .cfg-form { display: flex; flex-direction: column; gap: 22px; }
  .cfg-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .cfg-field { display: flex; flex-direction: column; gap: 8px; }
  .cfg-lbl { font-size: .6rem; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: rgba(240,235,216,.3); }
  .cfg-input, .cfg-ta {
    background: transparent; border: none; border-bottom: 1.5px solid rgba(240,235,216,.18);
    padding: 12px 0; font-family: var(--f-body); font-size: .88rem; font-weight: 300;
    color: var(--cream); outline: none; transition: border-color .2s;
  }
  .cfg-ta { resize: none; min-height: 80px; }
  .cfg-input:focus, .cfg-ta:focus { border-color: var(--bleu); }
  .cfg-input::placeholder, .cfg-ta::placeholder { color: rgba(240,235,216,.15); }

  @media (max-width: 960px) {
    #config { padding: 72px 0 0; }
    .cfg-wrap { padding: 0 20px 64px; }
    .cfg-title { font-size: clamp(2.2rem, 7vw, 3.2rem); }
    .cfg-row { grid-template-columns: 1fr; }
    .cfg-opts { grid-template-columns: 1fr 1fr; }
    .cfg-opt { padding: 20px 18px; }
  }
  @media (max-width: 560px) {
    #config { padding: 60px 0 0; }
    .cfg-wrap { padding: 0 18px 52px; }
    .cfg-head { margin-bottom: 36px; }
    .cfg-title { font-size: clamp(1.9rem, 9vw, 2.6rem); }
    .cfg-sub { font-size: .82rem; }
    .cfg-q { font-size: 1.05rem; margin-bottom: 22px; }
    .cfg-opts { grid-template-columns: 1fr; gap: 8px; }
    .cfg-opt { padding: 18px 16px; }
    .cfg-opt-n { font-size: 1.6rem; }
    .cfg-nav { margin-top: 32px; padding-top: 22px; flex-wrap: wrap; gap: 14px; }
    .cfg-next { padding: 12px 26px; font-size: .68rem; }
  }
</style>
