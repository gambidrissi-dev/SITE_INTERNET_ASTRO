---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const projets = (await getCollection('projets', ({ data }) => data.publie))
  .sort((a, b) => a.data.ordre - b.data.ordre || b.data.annee - a.data.annee);
---

<Base title="Projets — Le Studio — Collectif Cobalt" current="projets">
  <section class="page-hero">
    <div class="hero-bg-num" aria-hidden="true">01</div>
    <div class="s-label">Le Studio</div>
    <h1 class="page-title">PROJETS<br />RÉALISÉS.</h1>
    <p class="page-desc">{projets.length} projet{projets.length > 1 ? 's' : ''} référencé{projets.length > 1 ? 's' : ''} — réhabilitations, design d'espace et architecture d'intérieur en Nouvelle-Aquitaine.</p>
  </section>

  <section class="projets-grid">
    {projets.map((p) => (
      <a href={`/projets/${p.slug}`} class="proj-card">
        <div class="proj-img-wrap">
          <img src={p.data.couverture} alt={p.data.title} loading="lazy" />
          <div class="proj-overlay"></div>
        </div>
        <div class="proj-meta">
          <div class="proj-info">
            <span>{p.data.lieu}</span>
            {p.data.surface && <span>· {p.data.surface}</span>}
            <span>· {p.data.annee}</span>
          </div>
          <h2 class="proj-title">{p.data.title}.</h2>
          <p class="proj-excerpt">{p.data.excerpt}</p>
          <span class={`badge badge-${p.data.statut === 'livré' ? 'livré' : 'cours'}`}>
            {p.data.statut}
          </span>
        </div>
      </a>
    ))}
  </section>
</Base>

<style is:global>
  .page-hero {
    background: var(--noir); color: var(--cream);
    padding: 140px 44px 80px; position: relative; overflow: hidden;
  }
  .page-hero .hero-bg-num {
    position: absolute; right: -60px; bottom: -80px;
    font-family: var(--f-display); font-size: clamp(300px,40vw,500px);
    color: rgba(74,130,220,.07); line-height: 1; pointer-events: none; user-select: none;
  }
  .page-hero .s-label { color: var(--bleu); margin-bottom: 24px; }
  .page-title {
    font-family: var(--f-display);
    font-size: clamp(56px, 9vw, 110px);
    line-height: .9; margin-bottom: 32px;
  }
  .page-desc { max-width: 560px; color: rgba(240,235,216,.55); font-weight: 300; line-height: 1.75; }

  .projets-grid {
    padding: 80px 44px;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 28px;
  }
  .proj-card {
    display: flex; flex-direction: column; background: transparent;
    border-radius: var(--r-md); overflow: hidden;
    transition: transform .35s cubic-bezier(.25,.46,.45,.94);
  }
  .proj-card:hover { transform: translateY(-4px); }
  .proj-img-wrap { position: relative; aspect-ratio: 4/3; overflow: hidden; background: #222; }
  .proj-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s; }
  .proj-card:hover .proj-img-wrap img { transform: scale(1.04); }
  .proj-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(26,26,26,.5) 0%, transparent 50%);
    pointer-events: none;
  }
  .proj-meta { padding: 22px 4px; }
  .proj-info {
    display: flex; gap: 6px; flex-wrap: wrap;
    font-size: .62rem; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: rgba(26,26,26,.55);
    margin-bottom: 10px;
  }
  .proj-title {
    font-family: var(--f-serif); font-style: italic;
    font-size: 1.5rem; line-height: 1.1; margin-bottom: 10px;
  }
  .proj-excerpt {
    font-size: .9rem; line-height: 1.6; color: rgba(26,26,26,.65);
    font-weight: 300; margin-bottom: 14px;
  }

  @media (max-width: 720px) {
    .page-hero { padding: 110px 20px 56px; }
    .projets-grid { padding: 48px 20px; gap: 24px; grid-template-columns: 1fr; }
  }
</style>
