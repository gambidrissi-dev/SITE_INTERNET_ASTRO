---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page introuvable — Collectif Cobalt"
  description="La page demandée n'existe pas ou a été déplacée."
>
  <main id="main-content" class="e404-wrap">
    <div class="e404-num" aria-hidden="true">404</div>
    <div class="e404-label">Page introuvable</div>
    <h1 class="e404-title">Cette page n'existe pas.</h1>
    <p class="e404-sub">L'URL que vous avez suivie est incorrecte ou la page a été déplacée. Vous pouvez explorer le reste du site ci-dessous.</p>
    <nav class="e404-links" aria-label="Retour au site">
      <a href="/"               class="e404-link home">← Accueil</a>
      <a href="/studio"         class="e404-link studio">Le Studio</a>
      <a href="/atelier"        class="e404-link atelier">L'Atelier</a>
      <a href="/bleu-de-cobalt" class="e404-link bleu">Bleu de Cobalt</a>
      <a href="/media"          class="e404-link media">Le Média</a>
      <a href="/contact"        class="e404-link contact">Contact</a>
    </nav>
  </main>
</Base>

<style is:global>
  .stripe { background: linear-gradient(90deg, #4A82DC 25%, #F1CB4F 25% 50%, #5DA16B 50% 75%, #BB3B34 75%); }

  .e404-wrap {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 80px 44px;
    position: relative; overflow: hidden;
  }

  .e404-num {
    font-family: var(--f-display);
    font-size: clamp(140px, 22vw, 280px);
    font-weight: 800; letter-spacing: -.06em; line-height: 1;
    color: rgba(26,26,26,.06);
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none; user-select: none;
  }

  .e404-label {
    font-size: .62rem; font-weight: 700; letter-spacing: .22em;
    text-transform: uppercase; color: var(--bleu);
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 24px; position: relative; z-index: 1;
  }
  .e404-label::before { content: ''; width: 24px; height: 2px; background: var(--bleu); }

  .e404-title {
    font-family: var(--f-serif); font-style: italic;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.1; letter-spacing: -.02em;
    margin-bottom: 20px;
    position: relative; z-index: 1;
  }

  .e404-sub {
    font-size: .9rem; font-weight: 300; color: rgba(26,26,26,.45);
    line-height: 1.8; max-width: 420px;
    margin-bottom: 48px;
    position: relative; z-index: 1;
  }

  .e404-links {
    display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
    position: relative; z-index: 1;
  }
  .e404-link {
    font-size: .72rem; font-weight: 700; letter-spacing: .12em;
    text-transform: uppercase; padding: 12px 24px;
    border-radius: var(--r-pill); border: 1.5px solid currentColor;
    transition: opacity .2s;
  }
  .e404-link:hover { opacity: .65; }
  .e404-link.home    { color: var(--bleu); }
  .e404-link.studio  { color: var(--bleu); }
  .e404-link.atelier { color: var(--vert); }
  .e404-link.bleu    { color: #B8940A; }
  .e404-link.media   { color: var(--rouge); }
  .e404-link.contact { color: rgba(26,26,26,.4); border-color: rgba(26,26,26,.2); }

  @media (max-width: 560px) {
    .e404-wrap { padding: 60px 20px; }
    .e404-links { flex-direction: column; align-items: center; }
  }
</style>
