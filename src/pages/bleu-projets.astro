---
import Base from '../layouts/Base.astro';
---

<Base
  title="Projets — Bleu de Cobalt · Collectif Cobalt"
  description="Réalisations des alternants Bleu de Cobalt — missions cabinets, particuliers et interne Cobalt en Nouvelle-Aquitaine."
  current="bleu-projets"
>
  <!-- HERO -->
  <div class="page-hero">
    <div class="sr">
      <div class="s-label">Bleu de Cobalt — Réalisations</div>
      <h1 class="page-hero-title">PROJETS<br /><em>menés par les alternants</em>.</h1>
    </div>
    <p class="page-hero-sub sr sr-d2">Chaque mission Bleu débouche sur un livrable réel. Pas de simulation, pas de cas d'école : des plans signés, des permis déposés, des chantiers suivis. Voici les premiers projets en route — galerie en construction au fil des missions.</p>
  </div>

  <!-- FILTERS -->
  <div class="proj-filters">
    <span class="proj-filter-label">Filtrer par</span>
    <button class="filter-btn active" data-filter="all">Tous</button>
    <button class="filter-btn" data-filter="cabinet">Pour cabinet</button>
    <button class="filter-btn" data-filter="particulier">Pour particulier</button>
    <button class="filter-btn" data-filter="interne">Interne Cobalt</button>
  </div>

  <!-- GRILLE -->
  <div class="projets-grid">

    <!-- Row 1 — pleine largeur -->
    <div class="proj-row proj-row-1 sr">
      <a href="/contact" class="proj-card placeholder" data-cat="cabinet" style="min-height:380px">
        <div class="proj-card-inner">
          <div class="pc-head">
            <span class="pc-fmt">Mission · Cabinet partenaire</span>
            <span class="pc-yr">2026</span>
          </div>
          <div class="pc-body">
            <div class="pc-by">Alternant · L. (Bac+4 archi)</div>
            <h2 class="pc-title">Renfort esquisse — extension maison à Pessac.</h2>
            <p class="pc-desc">Mission 6 semaines pour un cabinet en sous-charge. Production de l'esquisse complète, plans 1:50, vue 3D. Validé client, déposé en mairie.</p>
            <div class="pc-info"><span>6 semaines</span><span>Cabinet · Bordeaux</span><span>Encadrement Cobalt</span></div>
          </div>
        </div>
      </a>
    </div>

    <!-- Row 2 -->
    <div class="proj-row proj-row-2 sr sr-d1">
      <a href="/contact" class="proj-card placeholder" data-cat="particulier" style="min-height:340px">
        <div class="proj-card-inner">
          <div class="pc-head">
            <span class="pc-fmt">Mission · Particulier</span>
            <span class="pc-yr">2026</span>
          </div>
          <div class="pc-body">
            <div class="pc-by">Alternants · M. + T. (binôme)</div>
            <h2 class="pc-title">Réagencement T3 à Mérignac.</h2>
            <p class="pc-desc">Famille avec petit budget. Plans, choix matières, suivi entreprises. 3 mois.</p>
            <div class="pc-info"><span>3 mois</span><span>65 m²</span><span>Budget client · 4k €</span></div>
          </div>
        </div>
      </a>
      <a href="/contact" class="proj-card placeholder" data-cat="cabinet" style="min-height:340px">
        <div class="proj-card-inner">
          <div class="pc-head">
            <span class="pc-fmt">Mission · Cabinet partenaire</span>
            <span class="pc-yr">2026</span>
          </div>
          <div class="pc-body">
            <div class="pc-by">Alternant · S. (BTS design d'espace)</div>
            <h2 class="pc-title">Modélisation 3D — projet hôtelier.</h2>
            <p class="pc-desc">Production 12 vues 3D pour présentation client. Mission ponctuelle 4 semaines.</p>
            <div class="pc-info"><span>4 semaines</span><span>Cabinet · Pays Basque</span></div>
          </div>
        </div>
      </a>
    </div>

    <!-- Row 3 -->
    <div class="proj-row proj-row-3 sr sr-d2">
      <a href="/contact" class="proj-card placeholder" data-cat="interne" style="min-height:300px">
        <div class="proj-card-inner">
          <div class="pc-head">
            <span class="pc-fmt">Mission · Interne Cobalt</span>
            <span class="pc-yr">2026</span>
          </div>
          <div class="pc-body">
            <div class="pc-by">Alternant · J.</div>
            <h2 class="pc-title">Études matières — projet Île-de-Ré.</h2>
            <p class="pc-desc">Recherche matériaux locaux, fiches techniques, échantillons.</p>
            <div class="pc-info"><span>2 mois</span><span>Studio</span></div>
          </div>
        </div>
      </a>
      <a href="/contact" class="proj-card placeholder" data-cat="particulier" style="min-height:300px">
        <div class="proj-card-inner">
          <div class="pc-head">
            <span class="pc-fmt">Mission · Particulier</span>
            <span class="pc-yr">2026</span>
          </div>
          <div class="pc-body">
            <div class="pc-by">Alternant · A.</div>
            <h2 class="pc-title">Conseil aménagement studio 28 m².</h2>
            <p class="pc-desc">Plans + moodboard pour locataire. Budget 800 €.</p>
            <div class="pc-info"><span>3 sem.</span><span>Bordeaux</span></div>
          </div>
        </div>
      </a>
      <a href="/contact" class="proj-card placeholder" data-cat="cabinet" style="min-height:300px">
        <div class="proj-card-inner">
          <div class="pc-head">
            <span class="pc-fmt">Mission · Cabinet partenaire</span>
            <span class="pc-yr">2026</span>
          </div>
          <div class="pc-body">
            <div class="pc-by">Alternant · C.</div>
            <h2 class="pc-title">Documents PRO — réhabilitation école.</h2>
            <p class="pc-desc">Production plans techniques, détails 1:5, CCTP.</p>
            <div class="pc-info"><span>8 semaines</span><span>Cabinet · Limoges</span></div>
          </div>
        </div>
      </a>
    </div>

  </div>

  <!-- WAITING BAND -->
  <div class="waiting-band sr">
    <div>
      <div class="s-label" style="color:rgba(240,235,216,.45)">Confier une mission</div>
      <h2 class="wb-title">UN PROJET <em>à confier</em><br />à nos alternants ?</h2>
    </div>
    <div>
      <p class="wb-body">Cabinets en sous-charge, particuliers à budget serré : Bleu de Cobalt place des alternants encadrés sur vos missions courtes. Cadre associatif, conventions simplifiées, livrable supervisé par un praticien.</p>
      <div class="wb-cta-row">
        <a href="/bleu-cabinets" class="btn btn-cream"><span>Vous êtes un cabinet →</span></a>
        <a href="/bleu-particuliers" class="btn btn-outline" style="color:var(--cream); border-color:rgba(240,235,216,.4)"><span>Vous êtes particulier →</span></a>
      </div>
    </div>
  </div>

  <!-- MARQUEE -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      <div class="marquee-item">MISSIONS RÉELLES<div class="marquee-sep"></div></div>
      <div class="marquee-item"><span class="hi" style="color:var(--jaune)">ALTERNANCE</span><div class="marquee-sep"></div></div>
      <div class="marquee-item">PROJETS LIVRÉS<div class="marquee-sep"></div></div>
      <div class="marquee-item"><span class="hi" style="color:var(--jaune)">CABINETS</span><div class="marquee-sep"></div></div>
      <div class="marquee-item">BLEU DE COBALT<div class="marquee-sep"></div></div>
      <div class="marquee-item"><span class="hi" style="color:var(--jaune)">PARTICULIERS</span><div class="marquee-sep"></div></div>
      <div class="marquee-item">MISSIONS RÉELLES<div class="marquee-sep"></div></div>
      <div class="marquee-item"><span class="hi" style="color:var(--jaune)">ALTERNANCE</span><div class="marquee-sep"></div></div>
      <div class="marquee-item">PROJETS LIVRÉS<div class="marquee-sep"></div></div>
      <div class="marquee-item"><span class="hi" style="color:var(--jaune)">CABINETS</span><div class="marquee-sep"></div></div>
      <div class="marquee-item">BLEU DE COBALT<div class="marquee-sep"></div></div>
      <div class="marquee-item"><span class="hi" style="color:var(--jaune)">PARTICULIERS</span><div class="marquee-sep"></div></div>
    </div>
  </div>
</Base>

<script is:inline>
  document.querySelectorAll('.filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const f = btn.dataset.filter;
      document.querySelectorAll('.proj-row').forEach((row) => {
        const cards = row.querySelectorAll('.proj-card');
        let visible = 0;
        cards.forEach((c) => {
          const show = f === 'all' || c.dataset.cat === f;
          c.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        row.style.display = visible === 0 ? 'none' : '';
      });
    });
  });
</script>

<style is:global>
  .stripe { background: linear-gradient(90deg, var(--jaune) 25%, var(--noir) 25% 50%, var(--jaune) 50% 75%, var(--noir) 75%); }

  /* PAGE HERO */
  .page-hero {
    padding: 140px 44px 80px; background: var(--jaune);
    border-bottom: 2px solid var(--noir);
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: end;
  }
  .page-hero .s-label { color: rgba(26,26,26,.6); }
  .page-hero .s-label::before { background: rgba(26,26,26,.6); }
  .page-hero-title { font-family: var(--f-display); font-size: clamp(64px,10vw,130px); line-height: .86; letter-spacing: -.02em; color: var(--noir); }
  .page-hero-title em { font-family: var(--f-serif); font-style: italic; color: var(--cream); font-weight: 400; }
  .page-hero-sub { font-size: .92rem; line-height: 1.85; font-weight: 300; color: rgba(26,26,26,.7); }

  /* FILTERS */
  .proj-filters {
    padding: 32px 44px; display: flex; gap: 8px; align-items: center;
    border-bottom: 2px solid var(--noir); background: var(--cream); flex-wrap: wrap;
  }
  .proj-filter-label { font-size: .62rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; color: rgba(26,26,26,.35); margin-right: 8px; }
  .filter-btn {
    padding: 7px 18px; border: 1.5px solid rgba(26,26,26,.2); border-radius: var(--r-pill);
    font-family: var(--f-body); font-size: .68rem; font-weight: 600;
    letter-spacing: .1em; text-transform: uppercase; background: transparent;
    color: rgba(26,26,26,.5); transition: all .2s;
  }
  .filter-btn:hover, .filter-btn.active { background: var(--jaune); color: var(--noir); border-color: var(--jaune); }

  /* GRID */
  .projets-grid { padding: 40px 44px 100px; background: var(--cream); }
  .proj-row { margin-top: 20px; display: grid; gap: 20px; }
  .proj-row-1  { grid-template-columns: 1fr; }
  .proj-row-2  { grid-template-columns: 1fr 1fr; }
  .proj-row-3  { grid-template-columns: 1fr 1fr 1fr; }

  .proj-card {
    position: relative; overflow: hidden; display: block;
    background: var(--noir); border-radius: var(--r-md);
    border: 1.5px solid var(--noir);
    min-height: 320px;
  }
  .proj-card.placeholder {
    background: repeating-linear-gradient(45deg, rgba(241,203,79,.20) 0 14px, rgba(241,203,79,.08) 14px 28px);
    border: 1px dashed rgba(26,26,26,.45);
  }
  .proj-card-inner { position: absolute; inset: 0; padding: 28px; display: flex; flex-direction: column; justify-content: space-between; }
  .proj-card.placeholder .proj-card-inner { color: var(--noir); }
  .pc-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
  .pc-fmt { font-size: .58rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: rgba(26,26,26,.6); padding: 4px 10px; background: var(--cream); border-radius: var(--r-pill); border: 1px solid rgba(26,26,26,.15); }
  .pc-yr { font-family: var(--f-display); font-size: 18px; color: rgba(26,26,26,.55); }
  .pc-by { font-size: .58rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: rgba(26,26,26,.55); margin-bottom: 10px; }
  .pc-title { font-family: var(--f-display); font-size: clamp(20px,2.4vw,28px); line-height: 1.05; color: var(--noir); margin-bottom: 14px; }
  .pc-desc { font-size: .82rem; line-height: 1.6; font-weight: 300; color: rgba(26,26,26,.65); margin-bottom: 14px; max-width: 90%; }
  .pc-info { display: flex; gap: 12px; flex-wrap: wrap; font-size: .55rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: rgba(26,26,26,.45); padding-top: 12px; border-top: 1px solid rgba(26,26,26,.15); }

  /* WAITING */
  .waiting-band {
    background: var(--noir); padding: 80px 44px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    border-top: 2px solid var(--noir); border-bottom: 2px solid var(--noir);
  }
  .wb-title { font-family: var(--f-display); font-size: clamp(40px,5vw,64px); line-height: .9; color: var(--cream); }
  .wb-title em { font-family: var(--f-serif); font-style: italic; color: var(--jaune); font-weight: 400; }
  .wb-body { font-size: .92rem; line-height: 1.85; font-weight: 300; color: rgba(240,235,216,.6); }
  .wb-cta-row { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 24px; }

  @media (max-width: 960px) {
    .page-hero { grid-template-columns: 1fr; gap: 24px; padding: 110px 20px 52px; }
    .page-hero-title { font-size: clamp(48px, 11vw, 90px); }
    .proj-filters { padding: 22px 20px; gap: 6px; }
    .filter-btn { padding: 6px 14px; font-size: .62rem; }
    .projets-grid { padding: 24px 20px 64px; }
    .proj-row-1, .proj-row-2, .proj-row-3 { grid-template-columns: 1fr; }
    .proj-card-inner { padding: 22px; }
    .waiting-band { grid-template-columns: 1fr; gap: 32px; padding: 60px 20px; }
  }
  @media (max-width: 560px) {
    .page-hero { padding: 100px 18px 40px; }
    .page-hero-title { font-size: clamp(40px, 13vw, 64px); }
    .page-hero-sub { font-size: .85rem; }
    .proj-filters { padding: 18px 16px; }
    .proj-filter-label { width: 100%; margin-bottom: 6px; }
    .filter-btn { padding: 6px 12px; font-size: .58rem; letter-spacing: .08em; }
    .projets-grid { padding: 20px 16px 52px; }
    .proj-card-inner { padding: 18px; }
    .pc-title { font-size: 1.05rem; }
    .pc-desc { font-size: .78rem; }
    .waiting-band { padding: 48px 18px; gap: 24px; }
    .wb-title { font-size: clamp(28px, 8vw, 40px); }
    .wb-body { font-size: .85rem; }
  }
</style>
