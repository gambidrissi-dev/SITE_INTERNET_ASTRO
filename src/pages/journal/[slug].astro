---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';

export const getStaticPaths = (async () => {
  const articles = await getCollection('journal', ({ data }) => data.publie);
  return articles.map((a) => ({ params: { slug: a.slug }, props: { entry: a } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const fmt = d.date.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<Base
  title={`${d.title} — Journal — Collectif Cobalt`}
  description={d.excerpt}
  current="journal"
  ogImage={d.couverture ?? '/assets/OG-image/og-image.jpg'}
>
  <article class="article-page">
    <header class="article-page-hero">
      <a href="/journal" class="projet-back">← Retour au Journal</a>
      <div class="article-meta">
        {d.serie && <span class="article-serie">{d.serie}</span>}
        <span>{fmt}</span>
        <span>· {d.lecture}</span>
        <span>· par {d.auteur}</span>
      </div>
      <h1 class="article-page-title">{d.title}</h1>
      <p class="article-page-excerpt">{d.excerpt}</p>
    </header>

    {d.couverture && (
      <figure class="article-cover">
        <img src={d.couverture} alt={d.title} />
      </figure>
    )}

    {d.video_embed && (
      <div class="video-wrap">
        <iframe
          src={d.video_embed}
          title={d.title}
          width="100%"
          height="450"
          frameborder="0"
          allowfullscreen
        ></iframe>
      </div>
    )}

    <div class="prose">
      <Content />
    </div>

    <footer class="article-footer">
      <div class="article-tags">
        {d.tags.map((t) => <span class="tag">#{t}</span>)}
      </div>
      <a href="/journal" class="btn btn-cream"><span>← Retour au Journal</span></a>
    </footer>
  </article>
</Base>

<style is:global>
  .article-page { max-width: 760px; margin: 0 auto; padding: 110px 24px 80px; }
  .article-page-hero { margin-bottom: 48px; }
  .article-page-title {
    font-family: var(--f-display);
    font-size: clamp(40px, 6vw, 64px);
    line-height: .95; margin: 16px 0 20px;
  }
  .article-page-excerpt {
    font-family: var(--f-serif); font-style: italic;
    font-size: 1.3rem; line-height: 1.5; color: rgba(26,26,26,.7);
  }
  .article-cover { margin: 0 0 48px; border-radius: var(--r-md); overflow: hidden; }
  .article-cover img { width: 100%; height: auto; display: block; }
  .video-wrap { margin: 0 0 48px; border-radius: var(--r-md); overflow: hidden; aspect-ratio: 16/9; }
  .video-wrap iframe { width: 100%; height: 100%; border: 0; }
  .article-footer {
    margin-top: 80px; padding-top: 32px;
    border-top: 1px solid rgba(26,26,26,.12);
    display: flex; flex-direction: column; gap: 32px; align-items: flex-start;
  }
</style>
